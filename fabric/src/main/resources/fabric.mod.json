{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}-${build_variant}+${minecraft_version}",
  "name": "${mod_name}",
  "description": "${description}",
  "authors": ["${mod_author}"],
  "contact": {},
  "license": "${license}",
  "environment": "*",
  "entrypoints": {
    "main": ["com.github.xandergos.terraindiffusionmc.TerrainDiffusionMc"],
    "client": ["com.github.xandergos.terraindiffusionmc.client.TerrainDiffusionMcClient"],
    "fabric-datagen": ["com.github.xandergos.terraindiffusionmc.client.TerrainDiffusionMcDataGenerator"]
  },
  "mixins": [
    "terrain-diffusion-mc.mixins.json",
    "terrain-diffusion-mc.client.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "${minecraft_version}",
    "java": ">=${java_version}",
    "fabric-api": "${fabric_version}"
  }
}
